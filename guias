<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Guías</title>

<style>
    body {
        margin: 0;
        font-family: 'IBM Plex Sans', sans-serif;
        background: #ffffff;
        color: #333;
        display: flex;
        height: 100vh;
    }

    /* PANEL IZQUIERDO */
    .left-panel {
        flex: 2;
        padding: 40px;
        border-right: 1px solid #ddd;
        overflow-y: auto;
        position: relative;
    }

    /* Flecha volver */
    .back-arrow {
        display: inline-flex;
        align-items: center;
        color: #1A73B8;
        text-decoration: none;
        margin-bottom: 20px;
        cursor: pointer;
    }

    .arrow-icon {
        width: 28px;
        height: 28px;
        transition: transform 0.2s;
    }

    .back-arrow:hover .arrow-icon {
        transform: translateX(-3px);
    }

    h1 {
        margin-top: 0;
        font-size: 2rem;
        color: #1A73B8;
    }

    /* PANEL DERECHO */
    .right-panel {
        flex: 1;
        padding: 40px 30px;
        background: #f7f9fc;
        overflow-y: auto;
        border-left: 1px solid #ddd;
    }

    .submenu-item {
        padding: 12px 10px;
        margin-bottom: 10px;
        cursor: pointer;
        border-radius: 4px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: #ffffff;
        border: 1px solid #ddd;
        transition: background 0.2s, border-color 0.2s;
    }

    .submenu-item:hover {
        background: #eef5ff;
    }

    .submenu-item.active {
        background: #dceaff;
        border-color: #1A73B8;
        font-weight: 600;
    }

    /* Flechas */
    .submenu-arrow {
        width: 18px;
        height: 18px;
        transition: transform 0.2s;
    }

    .submenu-item.active .submenu-arrow {
        transform: rotate(90deg);
    }

    /* CONTENIDO DINÁMICO */
    .content-block {
        display: none;
    }

    .content-block.active {
        display: block;
    }
</style>
</head>

<body>

    <!-- PANEL IZQUIERDO -->
    <div class="left-panel">

        <!-- Flecha volver -->
        <a href="index.html" class="back-arrow" aria-label="Volver">
            <svg viewBox="0 0 24 24" class="arrow-icon">
                <polyline points="15 6 9 12 15 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </a>

        <h1>Guías</h1>

        <!-- CONTENIDO DINÁMICO -->
        <div id="content-jubilacion" class="content-block active">
            <h2>Guías de Jubilación y Pensiones</h2>
            <p>Información práctica sobre jubilación, pensiones, trámites y planificación.</p>
        </div>

        <div id="content-salud" class="content-block">
            <h2>Guías de Salud y Bienestar</h2>
            <p>Recursos sobre salud física, mental, hábitos saludables y prevención.</p>
        </div>

        <div id="content-digitales" class="content-block">
            <h2>Guías Digitales</h2>
            <p>Uso de herramientas digitales, seguridad online y competencias tecnológicas.</p>
        </div>

        <div id="content-ocio" class="content-block">
            <h2>Guías de Ocio y Viajes</h2>
            <p>Recomendaciones de viajes, actividades culturales y propuestas de ocio.</p>
        </div>

        <div id="content-voluntariado" class="content-block">
            <h2>Guías de Participación y Voluntariado</h2>
            <p>Cómo participar en actividades sociales, voluntariado y proyectos comunitarios.</p>
        </div>

        <div id="content-formacion" class="content-block">
            <h2>Guías de Formación Permanente</h2>
            <p>Aprendizaje continuo, cursos, talleres y desarrollo personal.</p>
        </div>

    </div>

    <!-- PANEL DERECHO -->
    <div class="right-panel">

        <div class="submenu-item active" data-target="content-jubilacion">
            Guías de Jubilación y Pensiones
            <svg class="submenu-arrow" viewBox="0 0 24 24">
                <polyline points="9 6 15 12 9 18" fill="none" stroke="currentColor" stroke-width="2"/>
            </svg>
        </div>

        <div class="submenu-item" data-target="content-salud">
            Guías de Salud y Bienestar
            <svg class="submenu-arrow" viewBox="0 0 24 24">
                <polyline points="9 6 15 12 9 18" fill="none" stroke="currentColor" stroke-width="2"/>
            </svg>
        </div>

        <div class="submenu-item" data-target="content-digitales">
            Guías Digitales
            <svg class="submenu-arrow" viewBox="0 0 24 24">
                <polyline points="9 6 15 12 9 18" fill="none" stroke="currentColor" stroke-width="2"/>
            </svg>
        </div>

        <div class="submenu-item" data-target="content-ocio">
            Guías de Ocio y Viajes
            <svg class="submenu-arrow" viewBox="0 0 24 24">
                <polyline points="9 6 15 12 9 18" fill="none" stroke="currentColor" stroke-width="2"/>
            </svg>
        </div>

        <div class="submenu-item" data-target="content-voluntariado">
            Guías de Participación y Voluntariado
            <svg class="submenu-arrow" viewBox="0 0 24 24">
                <polyline points="9 6 15 12 9 18" fill="none" stroke="currentColor" stroke-width="2"/>
            </svg>
        </div>

        <div class="submenu-item" data-target="content-formacion">
            Guías de Formación Permanente
            <svg class="submenu-arrow" viewBox="0 0 24 24">
                <polyline points="9 6 15 12 9 18" fill="none" stroke="currentColor" stroke-width="2"/>
            </svg>
        </div>

    </div>

<script>
    const items = document.querySelectorAll('.submenu-item');
    const blocks = document.querySelectorAll('.content-block');

    function activarSeccion(targetId) {
        if (!targetId) return;

        items.forEach(i => i.classList.remove('active'));
        blocks.forEach(b => b.classList.remove('active'));

        const bloque = document.getElementById(targetId);
        if (bloque) bloque.classList.add('active');

        const menuItem = document.querySelector(`[data-target="${targetId}"]`);
        if (menuItem) menuItem.classList.add('active');
    }

    // Clic en menú lateral
    items.forEach(item => {
        item.addEventListener('click', () => {
            activarSeccion(item.dataset.target);
        });
    });

    // Activación por parámetro ?sec=
    const params = new URLSearchParams(window.location.search);
    const sec = params.get("sec");

    if (sec) {
        const map = {
            "jubilacion": "content-jubilacion",
            "salud": "content-salud",
            "digitales": "content-digitales",
            "ocio": "content-ocio",
            "voluntariado": "content-voluntariado",
            "formacion": "content-formacion"
        };

        activarSeccion(map[sec]);
    }
</script>

</body>
</html>
